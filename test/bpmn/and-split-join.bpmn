<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Defs_AND"
  targetNamespace="http://example.com/bpmn">

  <bpmn:process id="Process_AND" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1"/>
    <bpmn:parallelGateway id="Gateway_AND_Split"/>
    <bpmn:serviceTask id="Task_A" name="A"/>
    <bpmn:serviceTask id="Task_B" name="B"/>
    <bpmn:parallelGateway id="Gateway_AND_Join"/>
    <bpmn:endEvent id="EndEvent_1"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Gateway_AND_Split"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Gateway_AND_Split" targetRef="Task_A"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Gateway_AND_Split" targetRef="Task_B"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_A" targetRef="Gateway_AND_Join"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_B" targetRef="Gateway_AND_Join"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_AND_Join" targetRef="EndEvent_1"/>
  </bpmn:process>
</bpmn:definitions>
