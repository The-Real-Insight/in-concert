<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Defs_BoundaryTimer"
  targetNamespace="http://example.com/bpmn">

  <bpmn:process id="Process_BoundaryTimer" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1"/>
    <bpmn:serviceTask id="Task_A" name="A"/>
    <bpmn:boundaryEvent id="BoundaryTimer_1" attachedToRef="Task_A" cancelActivity="true">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_Escalate" name="Escalate"/>
    <bpmn:endEvent id="EndEvent_1"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_A"/>
    <bpmn:sequenceFlow id="Flow_Normal" sourceRef="Task_A" targetRef="EndEvent_1"/>
    <bpmn:sequenceFlow id="Flow_Timer" sourceRef="BoundaryTimer_1" targetRef="Task_Escalate"/>
    <bpmn:sequenceFlow id="Flow_E" sourceRef="Task_Escalate" targetRef="EndEvent_1"/>
  </bpmn:process>
</bpmn:definitions>
