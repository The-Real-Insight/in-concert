<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:tri="http://tri.com/schema/bpmn"
  id="Defs_TimerStart"
  targetNamespace="http://example.com/bpmn">

  <bpmn:process id="Process_TimerStart" isExecutable="true">

    <bpmn:startEvent id="TimerStart" name="Every 10 seconds">
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle>R/PT10S</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_DoWork" name="Do work"
      tri:toolId="do-work"/>

    <bpmn:endEvent id="End"/>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="TimerStart" targetRef="Task_DoWork"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_DoWork" targetRef="End"/>

  </bpmn:process>

</bpmn:definitions>
