{
  "name": "tri-bpmn-engine",
  "version": "0.1.0",
  "description": "BPMN 2.0 subset execution engine with event sourcing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=src/",
    "test:conformance": "jest --testPathPattern=test/scripts/conformance --testTimeout=15000",
    "test:conformance:watch": "jest --testPathPattern=test/scripts/conformance --watch",
    "test:callback": "jest --testPathPattern=test/scripts/callback-demo --testTimeout=30000 --silent=false",
    "test:callback:user": "jest --testPathPattern=test/scripts/callback-demo --testNamePattern=\"User task\" --testTimeout=30000 --silent=false",
    "test:callback:service": "jest --testPathPattern=test/scripts/callback-demo --testNamePattern=\"Service task\" --testTimeout=30000 --silent=false",
    "test:integration": "ts-node scripts/test-integration.ts"
  },
  "keywords": ["bpmn", "workflow", "engine"],
  "license": "UNLICENSED",
  "dependencies": {
    "bpmn-moddle": "^9.0.4",
    "express": "^4.21.0",
    "mongodb": "^6.10.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
