{
  "name": "@the-real-insight/in-concert",
  "version": "0.3.4",
  "description": "BPMN 2.0 subset execution engine with event sourcing",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk/index.js",
    "./db": "./dist/db/index.js",
    "./local": "./dist/local.js",
    "./validator": "./dist/model/validator.js",
    "./tri-schema": "./dist/model/tri-schema.js",
    "./triggers": "./dist/triggers/index.js",
    "./triggers/timer": "./dist/triggers/timer/index.js",
    "./triggers/graph-mailbox": "./dist/triggers/graph-mailbox/index.js",
    "./triggers/sharepoint-folder": "./dist/triggers/sharepoint-folder/index.js",
    "./triggers/ai-listener": "./dist/triggers/ai-listener/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=src/",
    "test:conformance": "jest --testPathPattern=test/scripts/conformance --testTimeout=15000",
    "test:conformance:watch": "jest --testPathPattern=test/scripts/conformance --watch",
    "test:callback": "jest --testPathPattern=test/scripts/callback-demo --testTimeout=30000 --silent=false",
    "test:callback:user": "jest --testPathPattern=test/scripts/callback-demo --testNamePattern=\"User task\" --testTimeout=30000 --silent=false",
    "test:callback:service": "jest --testPathPattern=test/scripts/callback-demo --testNamePattern=\"Service task\" --testTimeout=30000 --silent=false",
    "test:integration": "ts-node scripts/test-integration.ts",
    "cli": "ts-node -r dotenv/config test/cli/interactive.ts",
    "server": "PORT=9100 ts-node -r ./src/server/load-env src/server/index.ts",
    "diagram:parallel": "mmdc -i readme/input-parallel-with-subprocess.mmd -o readme/input-parallel-with-subprocess.svg",
    "test:sdk": "jest --testPathPattern=test/sdk --testTimeout=20000 --runInBand",
    "test:worklist": "jest --testPathPattern=worklist --testTimeout=20000 --runInBand"
  },
  "keywords": [
    "bpmn",
    "workflow",
    "engine"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Real-Insight/in-concert.git"
  },
  "homepage": "https://github.com/The-Real-Insight/in-concert#readme",
  "bugs": {
    "url": "https://github.com/The-Real-Insight/in-concert/issues"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "dependencies": {
    "@the-real-insight/tri-model": "^0.0.748",
    "bpmn-moddle": "^9.0.4",
    "express": "^4.21.0",
    "mongodb": "^6.10.0",
    "multer": "^2.0.2",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
